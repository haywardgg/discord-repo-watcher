##############################################################################
# GitHub Repo Watcher - Configuration File
##############################################################################
# Copy this file to .env and fill in your settings.
# .env is gitignored and will not be overwritten by updates.
##############################################################################

# REQUIRED: Discord bot token
# Create a bot application at: https://discord.com/developers/applications
# Under "Bot" settings, create a token and copy it here.
DISCORD_BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN"

# OPTIONAL but recommended: GitHub personal access token for higher API rate limits
# Create one at: https://github.com/settings/tokens (no permissions needed)
# Without a token: 60 requests/hour. With a token: 5,000 requests/hour.
GITHUB_TOKEN=""

# FILE PATHS (optional — defaults to script directory if left empty/unset)
# Path to the list of repositories to watch (one per line)
# Default: ./repos.txt (relative to the script's location)
# REPO_LIST="/opt/discord-repo-watcher/repos.txt"

# Path to the state file that tracks last-seen commits
# Default: ./.repo-state (relative to the script's location)
# STATE_FILE="/opt/discord-repo-watcher/.repo-state"

# Path to the log file
# Default: ./repo-watcher.log (relative to the script's location)
# LOG_FILE="/opt/discord-repo-watcher/repo-watcher.log"

# RATE LIMIT HANDLING (optional — defaults shown below)
# Maximum number of times to retry on rate limit errors
MAX_RETRIES=3
# Delay in seconds between retries
RETRY_DELAY=5

# HELP COMMAND NAME (optional — default: "help")
# Set a custom name for the help command to avoid conflicts with other bots.
# Examples: HELP_COMMAND="repos-help"  →  use !repos-help instead of !help
#           HELP_COMMAND="watch"       →  use !watch instead of !help
HELP_COMMAND="help"

# NOTIFICATION INTERVAL (optional — default: 300 seconds / 5 minutes)
# How often the bot checks all watched repositories for new commits
# CHECK_INTERVAL=300

# MINIMUM COMMIT AGE (optional — default: 8 hours)
# Only send Discord notifications for commits older than this many hours.
# This prevents spam when you're actively pushing to a repo frequently.
# Set to 0 to disable the age filter and notify on every new commit.
# MIN_COMMIT_AGE_HOURS=8
